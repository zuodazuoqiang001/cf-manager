# Required: encryption key for encrypting stored API tokens (any random string, at least 16 chars)
ENCRYPTION_KEY=your-random-encryption-key-here

# Optional: protect the management UI with an API secret (leave empty to disable auth)
API_SECRET=

# Optional: HTTP/SOCKS5 proxy for Cloudflare API requests
# Examples: http://127.0.0.1:7890  socks5://127.0.0.1:1080
PROXY_URL=

# Optional: exposed port on the host (default: 3000)
APP_PORT=3000
